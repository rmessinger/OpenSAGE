<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Override the global TargetFramework from Directory.Build.props -->
    <TargetFramework></TargetFramework>
    <!-- Build only for the current OS; MAUI requires platform-specific workloads on non-Windows -->
    <TargetPlatformMinVersion Condition="$([MSBuild]::IsOSPlatform('windows'))">10.0.19041.0</TargetPlatformMinVersion>
    <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('windows'))">net10.0-windows</TargetFrameworks>
    <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('macos'))">net10.0-maccatalyst</TargetFrameworks>
    <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('linux'))">net10.0</TargetFrameworks>
    <!-- MAUI requires platform workloads; compile as a plain library on Linux -->
    <UseMaui Condition="$([MSBuild]::IsOSPlatform('linux'))">false</UseMaui>
    <UseMaui Condition="!$([MSBuild]::IsOSPlatform('linux'))">true</UseMaui>
    <!-- On Linux there is no MAUI entry point, so build as a library -->
    <OutputType Condition="$([MSBuild]::IsOSPlatform('linux'))">Library</OutputType>
    <RootNamespace>OpenSage.Tools.ReplaySketch.Maui</RootNamespace>
    <SingleProject>true</SingleProject>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Application identity -->
    <ApplicationTitle>OpenSAGE Replay Sketch</ApplicationTitle>
    <ApplicationId>com.opensage.replaysketch</ApplicationId>
    <ApplicationVersion>1</ApplicationVersion>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>

    <!-- Windows-specific packaging -->
    <WindowsPackageType>None</WindowsPackageType>
  </PropertyGroup>

  <ItemGroup>
    <!-- App icon (SVG not required; use a placeholder PNG) -->
    <MauiIcon Include="Resources\AppIcon\appicon.png" />
    <MauiSplashScreen Include="Resources\Splash\splash.png" Color="#1E1E1E" />
    <MauiFont Include="Resources\Fonts\*.ttf" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Controls" />
    <PackageReference Include="SkiaSharp.Views.Maui.Controls" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OpenSage.Tools.ReplaySketch.Core\OpenSage.Tools.ReplaySketch.Core.csproj" />
  </ItemGroup>

</Project>
