<?xml version="1.0" encoding="utf-8"?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenSage.Tools.ReplaySketch.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Dark theme base colours -->
            <Color x:Key="BackgroundColor">#1E1E1E</Color>
            <Color x:Key="SurfaceColor">#2D2D2D</Color>
            <Color x:Key="PrimaryColor">#569CD6</Color>
            <Color x:Key="TextColor">#D4D4D4</Color>
            <Color x:Key="TextDisabledColor">#808080</Color>
            <Color x:Key="ErrorColor">#F44747</Color>
            <Color x:Key="SuccessColor">#4EC9B0</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
