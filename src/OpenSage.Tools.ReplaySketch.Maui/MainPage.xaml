<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:OpenSage.Tools.ReplaySketch.Maui.Views"
             x:Class="OpenSage.Tools.ReplaySketch.Maui.MainPage"
             Title="OpenSAGE Replay Sketch"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">

    <Grid RowDefinitions="*,Auto">

        <!-- Three-column work area: left=200 fixed, centre=* (largest), right=340 fixed -->
        <Grid Grid.Row="0"
              ColumnDefinitions="200,*,340"
              Margin="4,0">

            <!-- Left: scenario / player-slot editor -->
            <Frame Grid.Column="0"
                   BorderColor="{AppThemeBinding Light=#CCC, Dark=#444}"
                   BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#252525}"
                   Padding="0" Margin="2" CornerRadius="4">
                <views:ScenarioView x:Name="ScenarioView"/>
            </Frame>

            <!-- Centre: map preview -->
            <Frame Grid.Column="1"
                   BorderColor="{AppThemeBinding Light=#CCC, Dark=#444}"
                   BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#252525}"
                   Padding="0" Margin="2" CornerRadius="4">
                <views:MapPreviewView x:Name="MapPreviewView"/>
            </Frame>

            <!-- Right: action sequence editor -->
            <Frame Grid.Column="2"
                   BorderColor="{AppThemeBinding Light=#CCC, Dark=#444}"
                   BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#252525}"
                   Padding="0" Margin="2" CornerRadius="4">
                <views:ActionSequenceView x:Name="ActionSequenceView"/>
            </Frame>

        </Grid>

        <!-- Bottom: validate / export / play strip -->
        <Frame Grid.Row="1"
               BorderColor="{AppThemeBinding Light=#CCC, Dark=#444}"
               BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#252525}"
               Padding="0" Margin="4,2" CornerRadius="4">
            <views:ExportView x:Name="ExportView"/>
        </Frame>

    </Grid>

</ContentPage>
