<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenSage.Tools.ReplaySketch.Maui.Views.ScenarioView"
             x:Name="Root">
    <ContentView.Resources>
        <Style TargetType="Label" x:Key="SectionHeader">
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#569CD6, Dark=#569CD6}"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
        <Style TargetType="Label" x:Key="FieldLabel">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333, Dark=#D4D4D4}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Entry" x:Key="FieldEntry">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333, Dark=#D4D4D4}"/>
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0F0F0, Dark=#3C3C3C}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Picker" x:Key="FieldPicker">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333, Dark=#D4D4D4}"/>
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0F0F0, Dark=#3C3C3C}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </ContentView.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="8" Spacing="4">

            <!-- Map selection -->
            <Label Text="Map" Style="{StaticResource SectionHeader}"/>
            <Picker x:Name="MapPicker" Style="{StaticResource FieldPicker}"
                    SelectedIndexChanged="OnMapPickerChanged"/>

            <!-- Map settings -->
            <Label Text="Map Settings" Style="{StaticResource SectionHeader}"/>
            <Grid ColumnDefinitions="*,80" RowDefinitions="Auto">
                <Label Grid.Column="0" Text="Base radius (wu)" Style="{StaticResource FieldLabel}"/>
                <Entry Grid.Column="1" x:Name="BaseRadiusEntry"
                       Style="{StaticResource FieldEntry}"
                       Keyboard="Numeric"
                       Completed="OnBaseRadiusCompleted"
                       Unfocused="OnBaseRadiusUnfocused"/>
            </Grid>

            <!-- Player slots -->
            <Label Text="Player Slots" Style="{StaticResource SectionHeader}"/>
            <CollectionView x:Name="SlotsCollectionView"
                            SelectionMode="Single"
                            SelectionChanged="OnSlotSelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="4,2">
                            <Label x:Name="SlotHeaderLabel"
                                   TextColor="{AppThemeBinding Light=#333, Dark=#D4D4D4}"
                                   FontSize="13"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Selected slot detail panel -->
            <VerticalStackLayout x:Name="SlotDetailPanel" IsVisible="False" Spacing="4" Padding="8,4">
                <Label Text="Name" Style="{StaticResource FieldLabel}"/>
                <Entry x:Name="PlayerNameEntry" Style="{StaticResource FieldEntry}"
                       Completed="OnPlayerNameCompleted"
                       Unfocused="OnPlayerNameUnfocused"/>

                <Label Text="Faction" Style="{StaticResource FieldLabel}"/>
                <Picker x:Name="FactionPicker" Style="{StaticResource FieldPicker}"
                        SelectedIndexChanged="OnFactionPickerChanged"/>

                <Grid ColumnDefinitions="*,60" RowDefinitions="Auto,Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0" Text="Color" Style="{StaticResource FieldLabel}"/>
                    <Entry Grid.Row="0" Grid.Column="1" x:Name="ColorEntry"
                           Style="{StaticResource FieldEntry}" Keyboard="Numeric"
                           Completed="OnColorCompleted" Unfocused="OnColorUnfocused"/>

                    <Label Grid.Row="1" Grid.Column="0" Text="Start position" Style="{StaticResource FieldLabel}"/>
                    <Entry Grid.Row="1" Grid.Column="1" x:Name="StartPosEntry"
                           Style="{StaticResource FieldEntry}" Keyboard="Numeric"
                           Completed="OnStartPosCompleted" Unfocused="OnStartPosUnfocused"/>

                    <Label Grid.Row="2" Grid.Column="0" Text="Team" Style="{StaticResource FieldLabel}"/>
                    <Entry Grid.Row="2" Grid.Column="1" x:Name="TeamEntry"
                           Style="{StaticResource FieldEntry}" Keyboard="Numeric"
                           Completed="OnTeamCompleted" Unfocused="OnTeamUnfocused"/>
                </Grid>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>
