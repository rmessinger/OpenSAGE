<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenSage.Tools.ReplaySketch.Maui.Views.ExportView"
             x:Name="Root">
    <HorizontalStackLayout Padding="8" Spacing="12" VerticalOptions="Center">

        <!-- Validate -->
        <Button x:Name="ValidateButton" Text="Validate"
                Clicked="OnValidateClicked"
                WidthRequest="110"/>

        <!-- Export -->
        <Button x:Name="ExportButton" Text="Export to Replays Dir"
                Clicked="OnExportClicked"
                WidthRequest="170"/>

        <!-- Play in Game -->
        <Button x:Name="PlayButton" Text="▶  Play in Game"
                Clicked="OnPlayClicked"
                WidthRequest="150"
                BackgroundColor="{AppThemeBinding Light=#4CAF50, Dark=#388E3C}"
                TextColor="White"/>

        <!-- Result label -->
        <Label x:Name="ResultLabel"
               VerticalOptions="Center"
               FontSize="13"
               LineBreakMode="WordWrap"
               MaximumWidthRequest="400"/>

    </HorizontalStackLayout>
</ContentView>
