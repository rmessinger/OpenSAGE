<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OpenSage.Tools.ReplaySketch.Maui.Views.ActionSequenceView"
             x:Name="Root">
    <ContentView.Resources>
        <Style TargetType="Label" x:Key="SectionHeader">
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#569CD6, Dark=#569CD6}"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
        <Style TargetType="Label" x:Key="FieldLabel">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333, Dark=#D4D4D4}"/>
            <Setter Property="VerticalOptions" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Entry" x:Key="FieldEntry">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333, Dark=#D4D4D4}"/>
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0F0F0, Dark=#3C3C3C}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Picker" x:Key="FieldPicker">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#333, Dark=#D4D4D4}"/>
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0F0F0, Dark=#3C3C3C}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </ContentView.Resources>

    <ScrollView>
        <VerticalStackLayout x:Name="ActionList" Padding="8" Spacing="6"/>
    </ScrollView>
</ContentView>
